# Website Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5174

# API Configuration
NEXT_PUBLIC_API_URL=https://api.suimfx.world
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.suimfx.world

# JWT Secret (should match main trading app)
JWT_SECRET=your_jwt_secret_here
