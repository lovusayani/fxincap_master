# .env.example - Copy to .env and fill with your values

# Database Configuration (fxincapapi uses PG*; see src/lib/database.ts)
PGHOST=forex-final-db-do-user-23389554-0.m.db.ondigitalocean.com
PGPORT=25060
PGUSER=doadmin
PGPASSWORD=your-password
PGDATABASE=defaultdb
PGSSLMODE=require
# Local Windows: leave false or omit. Set true only with a valid PGSSL_CA bundle.
PGSSL_REJECT_UNAUTHORIZED=false

# Legacy names (some tools still use these)
DB_HOST=forex-final-db-do-user-23389554-0.m.db.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=your-password
DB_NAME=defaultdb

# Server Configuration
PORT=6000
NODE_ENV=development

# Authentication
JWT_SECRET=your-secret-key

# CORS (comma-separated). Trade UI uses VITE_API_URL → browser Origin is the trade host, not the API.
# Include: production trade + admin + local dev origins if you lock CORS down.
# Leave empty to allow any origin (default when unset).
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://trade.fxincap.com,https://admin.fxincap.com

# Payment Gateway
OXAPAY_API_KEY=your-api-key
OXAPAY_WEBHOOK_SECRET=your-secret

# MetaAPI
METAAPI_TOKEN=your-token
METAAPI_ACCOUNT_ID=your-account-id

# WebSocket
WEBSOCKET_PORT=6020

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@fxincap.com
VERIFICATION_URL=https://admin.fxincap.com/deposits

# Admin
ADMIN_EMAIL=admin@fxincap.com
ADMIN_PASSWORD=change-this
