# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=forex_final

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# MetaAPI Configuration
METAAPI_TOKEN=your-metaapi-token-here
METAAPI_ACCOUNT_ID=your-metaapi-account-id-here

# WebSocket Configuration
WS_PORT=6020
VITE_WEBSOCKET_URL=wss://api.fxincap.com:6020

# Admin Configuration
ADMIN_EMAIL=admin@fxincap.com
ADMIN_PASSWORD=admin123

# OxaPay Configuration (Payment Gateway)
OXAPAY_API_KEY=your-oxapay-api-key
OXAPAY_MERCHANT_ID=your-merchant-id
OXAPAY_CALLBACK_URL=https://trade.fxincap.com/api/oxapay/callback
OXAPAY_RETURN_URL=https://trade.fxincap.com/wallet

# App Configuration
VITE_APP_NAME=SUIMFX Forex Trading Platform
VITE_APP_URL=https://trade.fxincap.com
