# Copy to .env (and optional .env.local). Use the SAME Postgres as fxincapapi / live server for the same tables.

# REST API (fxincapapi). Local dev: http://localhost:7000
VITE_API_URL=http://localhost:7000

# PostgreSQL (same variables as fxincapapi — one database, one set of tables)
PGHOST=your-managed-pg-host.example.com
PGPORT=25060
PGUSER=your_user
PGPASSWORD=your_password
PGDATABASE=fxincapmain
PGSSLMODE=require
PGSSL_REJECT_UNAUTHORIZED=false

DB_HOST=your-managed-pg-host.example.com
DB_PORT=25060
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=fxincapmain

PORT=3000
NODE_ENV=development
JWT_SECRET=change-me
WS_PORT=6020

# Optional: override public WS URL (default: ws://<trade-host>:4040)
# VITE_WS_STREAM_URL=ws://localhost:4040
