# Copy to .deploy.env on the server (same directory as deploy-prod.sh). Do not commit .deploy.env.
# Loaded by run-prod.sh (PM2 + webhook) and install-prod.sh (builds).
#
# GitHub webhook (existing — do not create a duplicate): Payload URL https://fxincap.com/hooks/deploy
# DEPLOY_WEBHOOK_SECRET here must match the secret configured on that webhook.

# Required for signature verification (must match GitHub webhook secret)
DEPLOY_WEBHOOK_SECRET=

# Branch this server deploys when the webhook fires (must match GitHub webhook branch filter)
DEPLOY_BRANCH=dev

# Public API origin embedded in fxincaptrade at build time (no trailing slash)
VITE_API_URL=https://api.fxincap.com

# Optional: set to 1 only if deploy dir has no .git and you only want rebuild/restart (not push-to-live)
# DEPLOY_ALLOW_NO_GIT=0
